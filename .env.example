# ── Database ──────────────────────────────────────────────────────────
# Docker (npm run db:start): port 5433
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/postgres"
# Local Homebrew Postgres: port 5432 — create DB first: createdb opportunities
# DATABASE_URL="postgresql://YOUR_USER@localhost:5432/opportunities"

# ── Admin auth ────────────────────────────────────────────────────────
SESSION_SECRET="replace-with-a-random-64-char-hex-string"
ADMIN_PASSWORD="replace-with-a-strong-password"

# ── Cron jobs ─────────────────────────────────────────────────────────
CRON_SECRET="replace-with-a-random-secret"

# ── ColorStack scraper ────────────────────────────────────────────────
# Comma-separated list of ColorStack-registered emails allowed to receive OTP.
COLORSTACK_ALLOWED_EMAILS="adedejd60502@uapb.edu"

# ── Scraper LLM (REUFinder / Pathways extraction) ─────────────────────
GOOGLE_AI_API_KEY="your-gemini-api-key"

# ── AI Assistant (public chat widget) ─────────────────────────────────
# Get yours at https://platform.openai.com/api-keys
# If omitted the widget still loads but shows a graceful "not configured" message.
OPENAI_API_KEY="sk-..."

# ── Public base URL (for OG tags + social share links) ────────────────
# Set to your Vercel deployment URL in production.
# In development, leave unset — the app falls back to window.location.origin.
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
